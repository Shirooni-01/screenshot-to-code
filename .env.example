# ============================================
# Screenshot to Code Generator — Environment
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Gemini API Key (required) — get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-api-key-here

# Gemini Model (optional)
GEMINI_MODEL=gemini-3-flash-preview

# Flask Settings
FLASK_DEBUG=false
PORT=5000
